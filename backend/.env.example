# Environment Configuration Template
# Copy this file to .env and update with your settings

# Environment: development, testing, production
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database
# Local dev (default): SQLite — no setup required, file created automatically.
DATABASE_URL=sqlite:///./judge_agent.db
# Production / PostgreSQL: uncomment and set the line below instead.
# DATABASE_URL=postgresql://user:password@localhost:5432/judge_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# DBOS durable execution system database (separate from app DB).
# Default SQLite is fine for local dev; use PostgreSQL in production.
DBOS_SYSTEM_DATABASE_URL=sqlite:///dbos_system.db

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# API Keys and Secrets
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY_HEADER=X-API-Key
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Logging
LOG_LEVEL=INFO
